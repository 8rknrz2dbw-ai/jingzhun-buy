# 中央氣象署 (CWA) 開放資料授權碼
# 取得：https://opendata.cwa.gov.tw → 註冊免費會員 → 會員專區 / API 授權碼
# ⚠ 只放後端（本機環境變數 / GitHub Actions Secret），前端永遠不可觸碰。
CWA_API_KEY=CWA-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# ── 急迫搶收通知（皆選配；都不設 → notify.py 只 dry-run 印訊息） ──
# LINE Messaging API（LINE 官方帳號 push；LINE Notify 已停用故不用）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TO=                         # 要收通知的 user / group id
# 通用 webhook（Slack / Discord / Telegram 橋接皆可，送 {"text": ...}）
NOTIFY_WEBHOOK_URL=
# deadline 幾小時內視為急迫（預設 18）
NOTIFY_DEADLINE_H=18
